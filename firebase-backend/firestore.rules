rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Match the user's specific folder
    match /users/{userId} {
      // 🔒 SECURITY CHECK: 
      // Only allow access if the requester's UID matches the folder name
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Apply the same strict rule to subcollections
      match /meetings/{meetingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /transcripts/{transcriptId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}